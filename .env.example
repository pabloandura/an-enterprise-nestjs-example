# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 64
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── PostgreSQL (Auth) ────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=
POSTGRES_DB=auth_db

# ─── MongoDB (Products + Orders) ──────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/ecommerce

# ─── File Storage ─────────────────────────────────────────────────────────────
# dev: 'local' | prod: 's3'
STORAGE_DRIVER=local

# Local disk (dev only)
UPLOADS_DEST=./uploads

# AWS S3 (prod only — leave blank in dev)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080
